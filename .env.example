# ==========================================
# REQUIRED: Core Infrastructure
# ==========================================

# PostgreSQL Connection
# Used by fastapi and celery worker
POSTGRES_USER=jobtailor
POSTGRES_PASSWORD=password
POSTGRES_DB=jobtailor
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis Message Broker
# Used for Celery task queuing
REDIS_URL=redis://localhost:6379/0

# MinIO / S3 Storage
# Used for saving user uploads and extracted text
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=jobtailor-documents
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Security
# Cryptographic key for securing browser session cookies
SECRET_KEY=supersecretkeypleasechangeme

# Frontend Access
# Required for CORS and OAuth redirects
FRONTEND_URL=http://localhost:3000

# ==========================================
# OPTIONAL: Integrations & Testing
# ==========================================

# LinkedIn OAuth Configuration
# Get from https://www.linkedin.com/developers/
# Leave MOCK_LINKEDIN=true to bypass OAuth checks for local dev without an internet connection or real LinkedIn App.
MOCK_LINKEDIN=true
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/auth/callback/linkedin
